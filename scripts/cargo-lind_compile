#!/bin/bash
set -e

shift

# Determine profile from arguments
PROFILE="debug"
CARGO_ARGS=("--target" "wasm32-wasip1")
CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-target}"

for arg in "$@"; do
    if [ "$arg" = "--release" ] || [ "$arg" = "-r" ]; then
        PROFILE="release"
    fi
    CARGO_ARGS+=("$arg")
done

# Set linker (allow override via environment variable)
LINKER="${LIND_WASM_LINKER:-/home/lind/lind-wasm/scripts/wasip1-clang.sh}"
export CARGO_TARGET_WASM32_WASIP1_LINKER="$LINKER"

# Set rustflags for wasm32-wasip1 target
export CARGO_TARGET_WASM32_WASIP1_RUSTFLAGS="\
-C link-self-contained=no \
-C target-feature=+crt-static,+atomics,+bulk-memory \
-C link-arg=-Wl,--import-memory \
-C link-arg=-Wl,--export-memory \
-C link-arg=-Wl,--shared-memory \
-C link-arg=-Wl,--max-memory=67108864 \
-C link-arg=-Wl,--export=__stack_pointer \
-C link-arg=-Wl,--export=__stack_low \
-C link-arg=-Wl,--export=__tls_base \
-C link-arg=-Wl,--export=pass_fptr_to_wt"

# Set wasm-opt and wasmtime paths (allow override via environment variables)
WASM_OPT_BIN="${WASM_OPT_BIN:-wasm-opt}"
WASMTIME_BIN="${WASMTIME_BIN:-wasmtime}"

# Lind wasi crate path (allow override via environment variable)
LIND_WASI_CRATE="${LIND_WASI_CRATE:-/home/lind/lind-wasm/src/lind-wasi-crate}"

# Auto-inject [patch.crates-io] to redirect the wasi crate to lind's fork.
# This makes Rust std import from the "lind" wasm module instead of
# "wasi_snapshot_preview1".
CARGO_TOML="Cargo.toml"
PATCHED=0
if [ -f "$CARGO_TOML" ] && [ -d "$LIND_WASI_CRATE" ]; then
    cp "$CARGO_TOML" "$CARGO_TOML.lind-backup"
    PATCHED=1
    cat >> "$CARGO_TOML" << PATCH

[patch.crates-io]
wasi = { path = "$LIND_WASI_CRATE" }
PATCH
fi

# Ensure Cargo.toml is restored on exit (success or failure)
cleanup() {
    if [ "$PATCHED" = "1" ] && [ -f "$CARGO_TOML.lind-backup" ]; then
        mv "$CARGO_TOML.lind-backup" "$CARGO_TOML"
    fi
}
trap cleanup EXIT

echo "Building with profile: $PROFILE"
cargo +nightly build -Z build-std=std,panic_abort "${CARGO_ARGS[@]}"

echo "-------------------------------"
# Find the wasm files in the appropriate profile directory
for f in $(find "$CARGO_TARGET_DIR/wasm32-wasip1/$PROFILE" -name "*.wasm" ! -name "*deps*" 2>/dev/null| sort -r); do
        lind_compile --opt-only "$f" 2> /dev/null || true
done
